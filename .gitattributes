# Default: treat everything as text, normalize to LF in the repo and on checkout.
* text=auto eol=lf

# Source & config — always LF.
*.go   text eol=lf
*.mod  text eol=lf
*.sum  text eol=lf
*.h    text eol=lf
*.c    text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.sh   text eol=lf

# Windows-only scripts keep CRLF.
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary assets — never touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.exe  binary
*.dll  binary
